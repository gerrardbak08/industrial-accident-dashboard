# ============================================================
# Supabase — required for local development and Vercel deploy
# ============================================================
# 1. Create a Supabase project at https://app.supabase.com
# 2. Go to: Project Settings → API
# 3. Copy the values below

# Project URL  (e.g. https://abcdefghijkl.supabase.co)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Service Role Key  (starts with "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...")
# WARNING: Never expose this key to the browser / client bundle.
# It is safe here because all Supabase calls are server-side only.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
